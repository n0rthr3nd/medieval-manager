# Port the gateway listens on (Tailscale Funnel will forward to this)
PORT=8080

# Local Ollama endpoint (default Ollama port on the same host)
OLLAMA_URL=http://127.0.0.1:11434

# Shared secret. The medieval-manager backend must send this in X-API-KEY.
# Generate with: openssl rand -hex 32
GATEWAY_API_KEY=change_me_to_a_long_random_string

# Per-IP rate limit (belt-and-suspenders; per-user limits live in the backend)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Upstream timeout for non-streaming requests
UPSTREAM_TIMEOUT_MS=120000
